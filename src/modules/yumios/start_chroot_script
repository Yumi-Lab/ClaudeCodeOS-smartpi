# shellcheck enable=require-variable-braces
set -Ee

# Set DEBIAN_FRONTEND to noninteractive
if [[ "${DEBIAN_FRONTEND}" != "noninteractive" ]]; then
    export DEBIAN_FRONTEND=noninteractive
fi

# Source CustomPIOS common.sh
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

## Step 1: Create release file
if [ -f "/etc/yumios_version" ]; then
    rm -f /etc/yumios_version
fi

function get_parent {
    grep VERSION_CODENAME /etc/os-release | cut -d '=' -f2
}

echo "${DIST_NAME} release ${DIST_VERSION} ($(get_parent))" > /etc/"${DIST_NAME,,}"-release

## Step 2: Symlink for moonraker compatibility
if [[ -f "/etc/armbian-release" ]]; then
    echo_green "Apply release file workaround (armbian based image) ..."
    ln -s /etc/"${DIST_NAME,,}"-release /etc/aaaa-release
fi

## Step 3: Install utilities
apt-get update --allow-releaseinfo-change
# shellcheck disable=SC2086
check_install_pkgs ${YUMIOS_DEPS}
