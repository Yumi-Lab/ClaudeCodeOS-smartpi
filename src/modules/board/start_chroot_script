# shellcheck enable=require-variable-braces
set -Ee

# Set DEBIAN_FRONTEND to noninteractive
if [[ "${DEBIAN_FRONTEND}" != "noninteractive" ]]; then
    export DEBIAN_FRONTEND=noninteractive
fi

# Source CustomPIOS common.sh
# shellcheck disable=SC1091
source /common.sh
install_cleanup_trap

## Step 1: Install system dependencies
echo_green "Installing Claude Code Board dependencies ..."
apt-get update
# shellcheck disable=SC2086
check_install_pkgs ${BOARD_DEPS}

## Step 2: Install Node.js from Debian repositories
## Note: Using Debian packages for compatibility with all architectures (armhf, arm64, amd64)
## NodeSource doesn't support armhf (32-bit ARM), so we use Debian packages universally
echo_green "Installing Node.js and npm from Debian repositories ..."
apt-get install --yes nodejs npm

echo_green "Node.js version: $(node --version)"
echo_green "npm version: $(npm --version)"

## Step 3: Create board installation directory
echo_green "Creating Claude Code Board installation directory ..."
mkdir -p /opt/claude-code-board
chmod 755 /opt/claude-code-board

## Step 4: Copy Claude Code Board from submodule vendor directory
echo_green "Copying Claude Code Board from submodule ..."
# Copy the entire board application from the vendor submodule
if [[ -d /vendor/claude-code-board ]]; then
    cp -r /vendor/claude-code-board/* /opt/claude-code-board/
    echo_green "Claude Code Board copied successfully"
else
    echo_red "ERROR: Submodule not found at /vendor/claude-code-board"
    exit 1
fi

## Step 5: Install npm dependencies
echo_green "Installing npm dependencies for Claude Code Board ..."
cd /opt/claude-code-board
# Install with CI (clean install, respects package-lock.json)
npm ci --production || { echo_red "FAILED: npm ci in /opt/claude-code-board"; exit 1; }

## Step 6: Create board data directory
echo_green "Creating Claude Code Board data directory ..."
mkdir -p "${BOARD_DATA_DIR}"
chmod 700 "${BOARD_DATA_DIR}"

## Step 7: Set proper permissions
echo_green "Setting permissions for Claude Code Board ..."
chown -R root:root /opt/claude-code-board
chmod -R 755 /opt/claude-code-board

## Step 8: Copy filesystem files (systemd service, env config)
echo_green "Installing systemd service and configuration files ..."
unpack /filesystem/root / || { echo_red "FAILED: unpack filesystem files"; exit 1; }

## Step 9: Enable systemd service on boot
echo_green "Enabling Claude Code Board service ..."
systemctl -q enable claude-code-board || { echo_red "FAILED: systemctl enable"; exit 1; }

echo_green "Claude Code Board module installation complete!"
